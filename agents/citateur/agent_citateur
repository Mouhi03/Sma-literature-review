#  6. AGENT CITATEUR — ORCHESTRATEUR
# ═════════════════════════════════════════════════════════════════════════════

class AgentCitateur:
    """
    Pipeline complet de vérification :
      1. Chargement de la revue et du corpus
      2. Extraction des claims et citations
      3. Résolution des citations [Auteur, Année] → doc_id
      4. Vérification RAG de chaque claim
      5. Vérification LLM croisée pour les cas incertains
      6. Audit de la bibliographie
      7. Génération du rapport et de la revue annotée
    """

    # Limite le nombre de vérifications LLM (coûteux en tokens)
    MAX_VERIFICATIONS_LLM = 20

    def __init__(self):
        self.client             = Groq(api_key=os.getenv("GROQ_API_KEY"))
        self.model              = "llama-3.3-70b-versatile"
        self.extracteur         = ExtracteurClaims()
        self.verificateur_llm   = VerificateurLLM()

    # ─────────────────────────────────────────────────────────────────────────
    #  CHARGEMENTS
    # ─────────────────────────────────────────────────────────────────────────

    def _charger(self, chemin_revue_json: str,
                  chemin_revue_md: str,
                  chemin_corpus: str) -> tuple:

        with open(chemin_corpus, "r", encoding="utf-8") as f:
            corpus = json.load(f)

        revue_json = {}
        if Path(chemin_revue_json).exists():
            with open(chemin_revue_json, "r", encoding="utf-8") as f:
                revue_json = json.load(f)

        texte_revue = ""
        if Path(chemin_revue_md).exists():
            with open(chemin_revue_md, "r", encoding="utf-8") as f:
                texte_revue = f.read()

        return corpus, revue_json, texte_revue

    def _construire_resume_corpus(self, corpus: list) -> str:
        """Résumé compact du corpus pour les vérifications LLM."""
        lignes = []
        for doc in corpus[:15]:
            lignes.append(
                f"- {doc.get('titre','')[:70]} "
                f"({doc.get('annee','?')}) : "
                f"{doc.get('contribution_principale','')[:100]}"
            )
        return "\n".join(lignes)

    # ─────────────────────────────────────────────────────────────────────────
    #  ÉTAPE 1 : EXTRACTION ET RÉSOLUTION DES CITATIONS
    # ─────────────────────────────────────────────────────────────────────────

    def _extraire_et_resoudre_citations(self, texte_revue: str,
                                         corpus: list) -> tuple:
        """
        Extrait tous les claims et résout chaque citation [Auteur, Année]
        vers un doc_id du corpus.
        Retourne (claims, citations_resolues, stats_resolution).
        """
        print("  → Extraction des claims et citations...")
        claims = self.extracteur.extraire_claims(texte_revue)
        print(f"    {len(claims)} claims extraits")

        resolveur         = ResolveurCitations(corpus)
        citations_resolues = []
        stats             = {"resolu": 0, "partiel": 0, "non_trouve": 0}

        for claim in claims:
            for cit in claim["citations_brutes"]:
                resolution = resolveur.resoudre(cit["auteur"], cit["annee"])

                citations_resolues.append({
                    "claim_id":      claim["claim_id"],
                    "citation_brute":f"[{cit['auteur']}, {cit['annee']}]",
                    "auteur_cite":   cit["auteur"],
                    "annee_citee":   cit["annee"],
                    "resolution":    resolution
                })

                statut = resolution["statut"]
                if statut in stats:
                    stats[statut] += 1

        print(f"    Résolution : {stats['resolu']} exactes | "
              f"{stats['partiel']} partielles | "
              f"{stats['non_trouve']} non trouvées")

        return claims, citations_resolues, stats

    # ─────────────────────────────────────────────────────────────────────────
    #  ÉTAPE 2 : VÉRIFICATION RAG DES CLAIMS
    # ─────────────────────────────────────────────────────────────────────────

    def _verifier_claims_rag(self, claims: list,
                              indexeur) -> list:
        """
        Vérifie chaque claim par recherche sémantique dans ChromaDB.
        """
        print(f"  → Vérification RAG de {len(claims)} claims...")
        verificateur = VerificateurClaimsRAG(indexeur)
        resultats    = []

        for i, claim in enumerate(claims):
            if i % 10 == 0:
                print(f"    [{i}/{len(claims)}]...")

            resultat_rag = verificateur.verifier_claim(claim)

            resultats.append({
                **claim,
                "verification_rag": resultat_rag
            })

        # Stats
        confirmes     = sum(1 for r in resultats if r["verification_rag"]["statut_rag"] == "confirme")
        incertains    = sum(1 for r in resultats if r["verification_rag"]["statut_rag"] == "incertain")
        non_supportes = sum(1 for r in resultats if r["verification_rag"]["statut_rag"] == "non_supporte")

        print(f"    Confirmés : {confirmes} | "
              f"Incertains : {incertains} | "
              f"Non supportés : {non_supportes}")

        return resultats

    # ─────────────────────────────────────────────────────────────────────────
    #  ÉTAPE 3 : VÉRIFICATION LLM CROISÉE
    # ─────────────────────────────────────────────────────────────────────────

    def _verifier_claims_llm(self, claims_verifies: list,
                               corpus_resume: str) -> list:
        """
        Vérification LLM croisée pour :
          - Claims "incertains" par le RAG (confirmation croisée)
          - Claims sans citation ET sans source RAG (détection hallucination)

        Limité à MAX_VERIFICATIONS_LLM pour ne pas épuiser les tokens.
        """
        print(f"  → Vérification LLM croisée (max {self.MAX_VERIFICATIONS_LLM})...")
        nb_llm = 0

        for claim in claims_verifies:
            rag = claim["verification_rag"]

            # Cas 1 : incertain RAG + source disponible → confirmation croisée
            if (rag["statut_rag"] == "incertain"
                    and rag["sources_proches"]
                    and nb_llm < self.MAX_VERIFICATIONS_LLM):

                meilleure_source = rag["sources_proches"][0]
                verdict_llm = self.verificateur_llm.verifier_claim_vs_source(
                    claim   = claim["claim_pur"],
                    extrait_source = meilleure_source["extrait"],
                    titre_source   = meilleure_source.get("titre", "")
                )
                claim["verification_llm"] = verdict_llm
                nb_llm += 1
                time.sleep(0.8)

            # Cas 2 : non supporté RAG + pas de citation → risque hallucination
            elif (rag["statut_rag"] == "non_supporte"
                    and not claim["a_citation"]
                    and nb_llm < self.MAX_VERIFICATIONS_LLM):

                verdict_hall = self.verificateur_llm.detecter_hallucination_llm(
                    claim         = claim["claim_pur"],
                    corpus_resume = corpus_resume
                )
                claim["verification_llm"] = verdict_hall
                # Mise à jour du flag hallucination
                claim["verification_rag"]["est_hallucination"] = (
                    verdict_hall.get("risque_hallucination") == "eleve"
                )
                nb_llm += 1
                time.sleep(0.8)

            else:
                claim.setdefault("verification_llm", None)

        print(f"    {nb_llm} vérifications LLM effectuées")
        return claims_verifies

    # ─────────────────────────────────────────────────────────────────────────
    #  ÉTAPE 4 : CLASSIFICATION FINALE DE CHAQUE CLAIM
    # ─────────────────────────────────────────────────────────────────────────

    def _classifier_claims(self, claims_verifies: list,
                             citations_resolues: list) -> list:
        """
        Attribue un statut final à chaque claim en combinant
        RAG + LLM + résolution de citation.

        Statuts finaux :
          ✅ valide          : confirmé RAG + citation résolue
          ⚠  citation_faible : confirmé RAG mais citation non résolue
          ❓ incertain       : incertain RAG, LLM partiel
          🔴 hallucination   : non supporté + LLM risque élevé
          📎 non_cite        : vrai mais sans citation (affirmation générale)
        """
        # Index citations par claim_id
        cit_par_claim = defaultdict(list)
        for c in citations_resolues:
            cit_par_claim[c["claim_id"]].append(c)

        for claim in claims_verifies:
            rag      = claim["verification_rag"]
            llm      = claim.get("verification_llm") or {}
            cits     = cit_par_claim.get(claim["claim_id"], [])
            a_cit_resolue = any(
                c["resolution"]["statut"] in ("resolu", "partiel")
                for c in cits
            )

            # Logique de classification
            if rag["est_hallucination"] or llm.get("risque_hallucination") == "eleve":
                statut_final = "hallucination"
                priorite     = "critique"

            elif rag["statut_rag"] == "confirme" and a_cit_resolue:
                statut_final = "valide"
                priorite     = "ok"

            elif rag["statut_rag"] == "confirme" and not claim["a_citation"]:
                statut_final = "non_cite"
                priorite     = "faible"

            elif rag["statut_rag"] == "confirme" and not a_cit_resolue:
                statut_final = "citation_faible"
                priorite     = "moyenne"

            elif llm.get("verdict") == "confirme":
                statut_final = "valide_llm"
                priorite     = "ok"

            elif llm.get("verdict") == "contredit":
                statut_final = "contredit"
                priorite     = "critique"

            elif not claim["a_citation"] and rag["statut_rag"] == "non_supporte":
                statut_final = "hallucination"
                priorite     = "critique"

            else:
                statut_final = "incertain"
                priorite     = "moyenne"

            claim["statut_final"]     = statut_final
            claim["priorite_action"]  = priorite
            claim["citations_revue"]  = cits

        return claims_verifies

    # ─────────────────────────────────────────────────────────────────────────
    #  GÉNÉRATION DE LA REVUE ANNOTÉE
    # ─────────────────────────────────────────────────────────────────────────

    def _annoter_revue(self, texte_revue: str,
                        claims_classifies: list) -> str:
        """
        Génère une version annotée de la revue avec des marqueurs
        de vérification sur chaque claim problématique.

        Annotations :
          🔴 [HALLUCINATION] — claim sans source
          ⚠  [CITATION MANQUANTE] — claim vrai mais non cité
          ❓ [INCERTAIN] — claim à vérifier
          ✅ [VÉRIFIÉ] — claim confirmé (optionnel, peut être omis)
        """
        texte_annote = texte_revue

        ICONES = {
            "hallucination":  "🔴 **[HALLUCINATION — source non trouvée]**",
            "contredit":      "❌ **[CONTREDIT PAR LE CORPUS]**",
            "citation_faible":"⚠️  **[CITATION NON RÉSOLUE]**",
            "non_cite":       "📎 **[AFFIRMATION NON CITÉE]**",
            "incertain":      "❓ **[À VÉRIFIER]**"
        }

        # On annote uniquement les claims problématiques
        for claim in claims_classifies:
            statut = claim["statut_final"]
            if statut in ICONES:
                phrase    = claim["phrase_originale"]
                annotee   = f"{ICONES[statut]} {phrase}"
                texte_annote = texte_annote.replace(phrase, annotee, 1)

        return texte_annote

    # ─────────────────────────────────────────────────────────────────────────
    #  GÉNÉRATION DU RAPPORT MARKDOWN
    # ─────────────────────────────────────────────────────────────────────────

    def _generer_rapport_md(self, rapport: dict, dossier_output: str):
        meta    = rapport["meta"]
        stats   = rapport["stats_claims"]
        audit   = rapport["audit_bibliographie"]

        lignes = []
        lignes.append("# Rapport de Vérification des Citations\n")
        lignes.append(
            f"*{meta['nb_claims_total']} claims analysés | "
            f"{meta['nb_citations_extraites']} citations extraites | "
            f"{meta['nb_articles_corpus']} articles dans le corpus*\n"
        )
        lignes.append("---\n")

        # ── Score global ──────────────────────────────────────────────────
        score = meta.get("score_fiabilite", 0)
        emoji = "✅" if score >= 80 else "⚠️" if score >= 60 else "🔴"
        lignes.append(f"## Score de fiabilité : {emoji} {score}/100\n")

        lignes.append("## Résumé des vérifications\n")
        lignes.append(f"| Statut | Nombre |")
        lignes.append(f"|--------|--------|")
        for statut, nb in stats.items():
            lignes.append(f"| {statut} | {nb} |")
        lignes.append("")

        # ── Hallucinations ────────────────────────────────────────────────
        hallus = [
            c for c in rapport["claims_classifies"]
            if c["statut_final"] == "hallucination"
        ]
        if hallus:
            lignes.append(f"## 🔴 Hallucinations détectées ({len(hallus)})\n")
            for h in hallus:
                lignes.append(f"**Claim** : {h['claim_pur'][:120]}...")
                lignes.append(f"*Score similarité max* : {h['verification_rag']['score_max']}")
                llm_info = h.get("verification_llm") or {}
                if llm_info.get("explication"):
                    lignes.append(f"*Analyse LLM* : {llm_info['explication']}")
                lignes.append("")

        # ── Citations non résolues ────────────────────────────────────────
        fantomes = audit.get("citations_fantomes", [])
        if fantomes:
            lignes.append(f"## ⚠️ Citations non résolues ({len(fantomes)})\n")
            vus = set()
            for f in fantomes:
                cit = f.get("citation_brute", "")
                if cit not in vus:
                    lignes.append(f"- `{cit}` — non trouvée dans le corpus")
                    vus.add(cit)
            lignes.append("")

        # ── Audit bibliographie ───────────────────────────────────────────
        lignes.append("## Audit bibliographie\n")
        lignes.append(f"- **Couverture du corpus** : {audit['taux_couverture_corpus']}%")
        lignes.append(f"- **Articles non cités** : {audit['nb_articles_non_cites']}")
        lignes.append(f"- **Incohérences metadata** : {len(audit.get('incoherences_metadata',[]))}")
        lignes.append(f"- **Verdict** : {audit['verdict_bibliographie']}\n")

        if audit.get("articles_non_cites"):
            lignes.append("**Articles du corpus jamais cités :**\n")
            for art in audit["articles_non_cites"][:5]:
                lignes.append(f"- {art['titre'][:70]} ({art['annee']})")
            lignes.append("")

        if audit.get("incoherences_metadata"):
            lignes.append("**Incohérences d'années :**\n")
            for inc in audit["incoherences_metadata"]:
                lignes.append(
                    f"- `{inc['citation']}` : "
                    f"cité {inc['annee_citee']} mais réel = {inc['annee_reelle']}"
                )
            lignes.append("")

        # ── Claims à corriger ─────────────────────────────────────────────
        a_corriger = [
            c for c in rapport["claims_classifies"]
            if c["priorite_action"] in ("critique", "moyenne")
            and c["statut_final"] != "hallucination"
        ]
        if a_corriger:
            lignes.append(f"## ❓ Claims à vérifier manuellement ({len(a_corriger)})\n")
            for c in a_corriger[:8]:
                lignes.append(f"**[{c['statut_final'].upper()}]** {c['claim_pur'][:100]}...")
                if c["verification_rag"]["sources_proches"]:
                    src = c["verification_rag"]["sources_proches"][0]
                    lignes.append(f"*Source proche (score={src['score_sim']})* : "
                                  f"{src['titre'][:60]}")
                lignes.append("")

        texte = "\n".join(lignes)
        path  = Path(dossier_output) / "rapport_citations.md"
        with open(path, "w", encoding="utf-8") as f:
            f.write(texte)
        print(f"[Citateur] Rapport MD → {path}")

    # ─────────────────────────────────────────────────────────────────────────
    #  RUNNER PRINCIPAL
    # ─────────────────────────────────────────────────────────────────────────

    def run(self, chemin_revue_json: str,
            chemin_revue_md: str,
            chemin_corpus: str,
            dossier_output: str,
            indexeur=None) -> dict:

        print(f"\n{'='*60}")
        print(f"  AGENT CITATEUR")
        print(f"{'='*60}")
        debut = time.time()
        Path(dossier_output).mkdir(parents=True, exist_ok=True)

        # ── Chargement ────────────────────────────────────────────────────
        corpus, revue_json, texte_revue = self._charger(
            chemin_revue_json, chemin_revue_md, chemin_corpus
        )
        registre_narrateur = revue_json.get("citations", [])
        corpus_resume      = self._construire_resume_corpus(corpus)

        print(f"[Citateur] {len(corpus)} articles | "
              f"{len(registre_narrateur)} citations Narrateur\n")

        if not texte_revue:
            print("[Citateur] ⚠  Aucun texte de revue trouvé. Arrêt.")
            return {}

        # ── Étape 1 : Extraction et résolution ────────────────────────────
        claims, citations_resolues, stats_res = \
            self._extraire_et_resoudre_citations(texte_revue, corpus)

        # ── Étape 2 : Vérification RAG ────────────────────────────────────
        if indexeur:
            claims = self._verifier_claims_rag(claims, indexeur)
        else:
            print("  ⚠  Pas d'indexeur fourni — vérification RAG ignorée.")
            for c in claims:
                c["verification_rag"] = {
                    "statut_rag": "non_verifie",
                    "score_max": 0.0,
                    "sources_proches": [],
                    "doc_id_confirme": None,
                    "est_hallucination": False
                }

        # ── Étape 3 : Vérification LLM croisée ───────────────────────────
        claims = self._verifier_claims_llm(claims, corpus_resume)

        # ── Étape 4 : Classification finale ──────────────────────────────
        claims = self._classifier_claims(claims, citations_resolues)

        # ── Étape 5 : Audit bibliographie ─────────────────────────────────
        print("  → Audit bibliographie...")
        refs_bib = self.extracteur.extraire_citations_bibliographie(texte_revue)
        auditeur = AuditeurBibliographie(corpus)
        audit    = auditeur.auditer(citations_resolues, refs_bib, registre_narrateur)

        # ── Étape 6 : Revue annotée ───────────────────────────────────────
        print("  → Génération de la revue annotée...")
        texte_annote = self._annoter_revue(texte_revue, claims)
        annote_path  = Path(dossier_output) / "revue_corrigee.md"
        with open(annote_path, "w", encoding="utf-8") as f:
            f.write(texte_annote)

        # ── Stats finales ─────────────────────────────────────────────────
        stats_claims = Counter(c["statut_final"] for c in claims)
        nb_hallus    = stats_claims.get("hallucination", 0)
        nb_valides   = stats_claims.get("valide", 0) + stats_claims.get("valide_llm", 0)
        nb_total     = len(claims)

        # Score de fiabilité (0-100)
        score_fiabilite = round(
            (nb_valides / nb_total * 70)
            + ((1 - nb_hallus / max(nb_total, 1)) * 30)
            if nb_total > 0 else 0
        )

        # ── Rapport final ─────────────────────────────────────────────────
        rapport = {
            "meta": {
                "nb_claims_total":       nb_total,
                "nb_citations_extraites":len(citations_resolues),
                "nb_articles_corpus":    len(corpus),
                "stats_resolution":      stats_res,
                "score_fiabilite":       score_fiabilite,
                "duree_secondes":        round(time.time() - debut, 1)
            },
            "stats_claims":       dict(stats_claims),
            "claims_classifies":  claims,
            "citations_resolues": citations_resolues,
            "audit_bibliographie":audit
        }

        # Sauvegarde JSON
        json_path = Path(dossier_output) / "rapport_citations.json"
        with open(json_path, "w", encoding="utf-8") as f:
            json.dump(rapport, f, ensure_ascii=False, indent=2)

        # Rapport Markdown
        self._generer_rapport_md(rapport, dossier_output)

        # ── Résumé console ────────────────────────────────────────────────
        print(f"\n{'='*60}")
        print(f"  RÉSUMÉ AGENT CITATEUR")
        print(f"{'='*60}")
        print(f"  Score de fiabilité     : {score_fiabilite}/100")
        print(f"  Claims analysés        : {nb_total}")
        print(f"  Validés                : {nb_valides}")
        print(f"  Hallucinations         : {nb_hallus}")
        print(f"  Citations non résolues : {audit['nb_citations_fantomes']}")
        print(f"  Couverture corpus      : {audit['taux_couverture_corpus']}%")
        print(f"  Durée totale           : {rapport['meta']['duree_secondes']}s")
        print(f"  Revue annotée          : {annote_path}")

        return rapport


