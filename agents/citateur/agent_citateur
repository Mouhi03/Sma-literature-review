#  3. VÉRIFICATEUR DE CLAIMS PAR RAG
# ═════════════════════════════════════════════════════════════════════════════

class VerificateurClaimsRAG:
    """
    Vérifie chaque claim par recherche sémantique dans ChromaDB.

    Pour chaque claim :
      1. Recherche les N chunks les plus similaires
      2. Si score_sim > SEUIL_CONFIRMATION → claim confirmé
      3. Si score_sim entre SEUIL_SIMILARITE et SEUIL_CONFIRMATION → incertain
      4. Si score_sim < SEUIL_SIMILARITE → potentielle hallucination
    """

    def __init__(self, indexeur):
        self.indexeur = indexeur

    def verifier_claim(self, claim: dict) -> dict:
        """
        Vérifie un claim par recherche sémantique.
        Retourne le statut de vérification et les sources trouvées.
        """
        texte_claim = claim["claim_pur"]

        # Recherche sémantique dans tous les chunks
        chunks_proches = self.indexeur.rechercher(
            requete     = texte_claim,
            n_resultats = N_CHUNKS_VERIFICATION
        )

        if not chunks_proches:
            return self._resultat_non_verifie(claim, "indexeur_vide")

        meilleur_score = chunks_proches[0]["score_sim"]
        meilleur_chunk = chunks_proches[0]

        # ── Statut selon le score ─────────────────────────────────────────
        if meilleur_score >= SEUIL_CONFIRMATION:
            statut_rag = "confirme"
        elif meilleur_score >= SEUIL_SIMILARITE_CLAIM:
            statut_rag = "incertain"
        else:
            statut_rag = "non_supporte"

        # Sources potentielles (tous chunks au dessus du seuil bas)
        sources = [
            {
                "doc_id":       c["doc_id"],
                "titre":        c.get("titre", ""),
                "section":      c.get("section_nom", ""),
                "score_sim":    c["score_sim"],
                "extrait":      c["texte"][:200]
            }
            for c in chunks_proches
            if c["score_sim"] >= SEUIL_SIMILARITE_CLAIM
        ]

        return {
            "claim_id":         claim["claim_id"],
            "statut_rag":       statut_rag,
            "score_max":        round(meilleur_score, 4),
            "sources_proches":  sources,
            "doc_id_confirme":  meilleur_chunk["doc_id"] if statut_rag == "confirme" else None,
            "est_hallucination": statut_rag == "non_supporte" and not claim["a_citation"]
        }

    def _resultat_non_verifie(self, claim: dict, raison: str) -> dict:
        return {
            "claim_id":         claim["claim_id"],
            "statut_rag":       "non_verifie",
            "score_max":        0.0,
            "sources_proches":  [],
            "doc_id_confirme":  None,
            "est_hallucination": False,
            "raison":           raison
        }


