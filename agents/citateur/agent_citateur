load_dotenv()

# Seuil de similarité cosine en dessous duquel un claim est considéré
# comme potentiellement halluciné (pas de chunk suffisamment proche)
SEUIL_SIMILARITE_CLAIM    = 0.35

# Seuil au dessus duquel on considère qu'un chunk confirme un claim
SEUIL_CONFIRMATION        = 0.55

# Nombre de chunks récupérés pour vérifier chaque claim
N_CHUNKS_VERIFICATION     = 5


# ═════════════════════════════════════════════════════════════════════════════
#  1. EXTRACTEUR DE CLAIMS ET CITATIONS
# ═════════════════════════════════════════════════════════════════════════════

class ExtracteurClaims:
    """
    Extrait du texte de la revue :
      - Les citations explicites [Auteur, Année] ou [Auteur et al., Année]
      - Les claims (affirmations factuelles associées à une citation)
      - Les phrases sans citation (potentiellement non sourcées)
    """

    # Pattern de citation académique
    # Capture : [Smith, 2020] [Smith & Jones, 2019] [Smith et al., 2021]
    PATTERN_CITATION = re.compile(
        r'\[([A-ZÀ-Ÿa-zà-ÿ\s\-\']+(?:\s*(?:&|et\s+al\.?|and)\s*'
        r'[A-ZÀ-Ÿa-zà-ÿ\s\-\']*)?)\s*,\s*((?:19|20)\d{2}[a-z]?)\]'
    )

    def extraire_claims(self, texte_revue: str) -> list:
        """
        Découpe la revue en phrases et pour chacune :
        - identifie les citations présentes
        - extrait le claim (phrase sans les balises de citation)
        - marque si la phrase a au moins une citation
        """
        # Découpe en phrases (point + majuscule ou saut de ligne)
        phrases = re.split(r'(?<=[.!?])\s+(?=[A-ZÀ-Ÿ«"])', texte_revue)

        claims = []
        for i, phrase in enumerate(phrases):
            phrase = phrase.strip()

            # Ignore les lignes trop courtes (titres, puces vides)
            if len(phrase) < 40:
                continue

            # Ignore les lignes de bibliographie
            if phrase.startswith("- ") and "(" in phrase and ")" in phrase:
                continue

            # Extraction des citations dans la phrase
            citations_trouvees = self.PATTERN_CITATION.findall(phrase)

            # Texte du claim sans les balises de citation
            claim_pur = self.PATTERN_CITATION.sub("", phrase).strip()
            claim_pur = re.sub(r'\s{2,}', ' ', claim_pur)

            if len(claim_pur) < 30:
                continue

            claims.append({
                "claim_id":       f"claim_{i:04d}",
                "phrase_originale": phrase,
                "claim_pur":      claim_pur,
                "citations_brutes": [
                    {"auteur": c[0].strip(), "annee": c[1].strip()}
                    for c in citations_trouvees
                ],
                "a_citation":     len(citations_trouvees) > 0,
                "section":        self._detecter_section(phrase, i)
            })

        return claims

    def _detecter_section(self, phrase: str, index: int) -> str:
        """Heuristique simple pour deviner la section d'une phrase."""
        phrase_lower = phrase.lower()
        if any(k in phrase_lower for k in ["introduc", "contexte général"]):
            return "introduction"
        if any(k in phrase_lower for k in ["méthod", "approch", "technique"]):
            return "methodologie"
        if any(k in phrase_lower for k in ["débat", "controvers", "tension", "limite"]):
            return "debats"
        if any(k in phrase_lower for k in ["conclus", "synthès", "recommand"]):
            return "conclusion"
        if any(k in phrase_lower for k in ["état actuel", "récemment", "aujourd'hui"]):
            return "etat_actuel"
        return "corps"

    def extraire_citations_bibliographie(self, texte_revue: str) -> list:
        """
        Extrait les entrées de bibliographie du texte de la revue.
        Format attendu : - Auteur(s) (Année). *Titre*. Journal. doi
        """
        refs = []
        lignes = texte_revue.split("\n")
        in_references = False

        for ligne in lignes:
            if "## Références" in ligne or "## References" in ligne:
                in_references = True
                continue
            if in_references and ligne.startswith("##"):
                break
            if in_references and ligne.startswith("- "):
                refs.append(ligne[2:].strip())

        return refs


