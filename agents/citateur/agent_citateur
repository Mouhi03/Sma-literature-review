#  2. RÉSOLVEUR DE CITATIONS
# ═════════════════════════════════════════════════════════════════════════════

class ResolveurCitations:
    """
    Fait correspondre les citations [Auteur, Année] trouvées dans le texte
    aux articles réels du corpus (via doc_id).

    Utilise plusieurs stratégies de matching :
      1. Correspondance exacte nom + année
      2. Correspondance partielle (nom de famille seulement)
      3. Correspondance année seule (dernier recours)
    """

    def __init__(self, corpus: list):
        self.corpus = corpus
        # Index multi-clé pour le matching rapide
        self._construire_index()

    def _construire_index(self):
        """Construit plusieurs index pour le matching des citations."""
        # Index exact : "smith2020" → [doc]
        self.index_exact    = defaultdict(list)
        # Index partiel : "smith" → [doc]
        self.index_partiel  = defaultdict(list)
        # Index année : 2020 → [doc]
        self.index_annee    = defaultdict(list)

        for doc in self.corpus:
            annee   = str(doc.get("annee") or "")
            auteurs = doc.get("auteurs") or []

            for auteur in auteurs:
                # Nom de famille (dernier mot de la chaîne)
                parties = str(auteur).strip().split()
                if not parties:
                    continue
                nom_famille = parties[-1].lower()
                cle_exacte  = f"{nom_famille}{annee}"

                self.index_exact[cle_exacte].append(doc)
                self.index_partiel[nom_famille].append(doc)

            if annee:
                self.index_annee[annee].append(doc)

    def resoudre(self, auteur_cite: str, annee_citee: str) -> dict:
        """
        Tente de résoudre une citation [Auteur, Année] vers un doc du corpus.

        Retourne un dict avec :
          - doc_id (si trouvé)
          - titre, auteurs, annee
          - statut : "resolu" | "partiel" | "non_trouve"
          - confiance : 1.0 | 0.7 | 0.3
        """
        # Nettoyage
        auteur_clean = re.sub(r'\bet\s+al\.?\b', '', auteur_cite, flags=re.IGNORECASE)
        auteur_clean = re.sub(r'[&,]', ' ', auteur_clean).strip().lower()
        mots_auteur  = [m for m in auteur_clean.split() if len(m) > 2]

        # ── Stratégie 1 : correspondance exacte (nom + année) ────────────
        for mot in mots_auteur:
            cle = f"{mot}{annee_citee}"
            if cle in self.index_exact:
                docs = self.index_exact[cle]
                if docs:
                    return self._formater_resultat(docs[0], "resolu", 1.0)

        # ── Stratégie 2 : correspondance partielle (nom seul) ─────────────
        candidats_nom = []
        for mot in mots_auteur:
            if mot in self.index_partiel:
                candidats_nom.extend(self.index_partiel[mot])

        if candidats_nom:
            # Filtrer par année si possible
            candidats_annee = [
                d for d in candidats_nom
                if str(d.get("annee", "")) == annee_citee
            ]
            if candidats_annee:
                return self._formater_resultat(candidats_annee[0], "partiel", 0.75)
            # Sans filtre année
            return self._formater_resultat(candidats_nom[0], "partiel", 0.5)

        # ── Stratégie 3 : année seule ─────────────────────────────────────
        if annee_citee in self.index_annee:
            docs = self.index_annee[annee_citee]
            if len(docs) == 1:
                return self._formater_resultat(docs[0], "partiel", 0.3)

        return {
            "doc_id":    None,
            "titre":     None,
            "auteurs":   [],
            "annee":     annee_citee,
            "statut":    "non_trouve",
            "confiance": 0.0,
            "auteur_cite": auteur_cite
        }

    def _formater_resultat(self, doc: dict, statut: str, confiance: float) -> dict:
        return {
            "doc_id":    doc.get("doc_id", ""),
            "titre":     doc.get("titre", ""),
            "auteurs":   doc.get("auteurs", []),
            "annee":     doc.get("annee"),
            "doi":       doc.get("doi"),
            "statut":    statut,
            "confiance": confiance
        }


