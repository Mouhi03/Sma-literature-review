#  5. AUDITEUR DE BIBLIOGRAPHIE
# ═════════════════════════════════════════════════════════════════════════════

class AuditeurBibliographie:
    """
    Vérifie la cohérence globale de la bibliographie :
      - Articles cités dans le texte mais absents de la bibliographie
      - Articles dans la bibliographie mais jamais cités dans le texte
      - Doublons dans la bibliographie
      - Articles du corpus non cités du tout
      - Cohérence des métadonnées (titre, année, auteurs)
    """

    def __init__(self, corpus: list):
        self.corpus    = corpus
        self.index_corpus = {
            doc["doc_id"]: doc for doc in corpus if doc.get("doc_id")
        }

    def auditer(self, citations_texte: list,
                citations_bibliographie: list,
                registre_narrateur: list) -> dict:
        """
        citations_texte          : toutes les citations résolues du texte
        citations_bibliographie  : entrées brutes de la section Références
        registre_narrateur       : registre doc_id de l'Agent Narrateur
        """

        # ── Doc IDs cités dans le texte ───────────────────────────────────
        doc_ids_cites = set(
            c["resolution"]["doc_id"]
            for c in citations_texte
            if c.get("resolution", {}).get("doc_id")
        )

        # ── Doc IDs dans le registre du Narrateur ─────────────────────────
        doc_ids_narrateur = set(
            r["doc_id"] for r in registre_narrateur if r.get("doc_id")
        )

        # ── Tous les doc IDs du corpus ─────────────────────────────────────
        doc_ids_corpus = set(self.index_corpus.keys())

        # ── Articles cités mais non dans le corpus ─────────────────────────
        fantomes = [
            c for c in citations_texte
            if c.get("resolution", {}).get("statut") == "non_trouve"
        ]

        # ── Articles du corpus jamais cités ───────────────────────────────
        non_cites = [
            {
                "doc_id": doc_id,
                "titre":  self.index_corpus[doc_id].get("titre", ""),
                "annee":  self.index_corpus[doc_id].get("annee")
            }
            for doc_id in doc_ids_corpus
            if doc_id not in doc_ids_cites
        ]

        # ── Doublons dans les citations du texte ───────────────────────────
        doc_id_counts = Counter(
            c["resolution"]["doc_id"]
            for c in citations_texte
            if c.get("resolution", {}).get("doc_id")
        )
        surexploites = [
            {"doc_id": did, "nb_citations": nb,
             "titre": self.index_corpus.get(did, {}).get("titre", "")}
            for did, nb in doc_id_counts.items() if nb > 5
        ]

        # ── Métadonnées incohérentes ───────────────────────────────────────
        incoherences = []
        for c in citations_texte:
            res = c.get("resolution", {})
            if res.get("statut") in ("resolu", "partiel") and res.get("doc_id"):
                doc      = self.index_corpus.get(res["doc_id"], {})
                annee_c  = c.get("annee_citee", "")
                annee_d  = str(doc.get("annee") or "")
                if annee_c and annee_d and annee_c != annee_d:
                    incoherences.append({
                        "citation":       c.get("citation_brute", ""),
                        "annee_citee":    annee_c,
                        "annee_reelle":   annee_d,
                        "titre":          doc.get("titre", ""),
                        "type":           "annee_incorrecte"
                    })

        # ── Taux de couverture ────────────────────────────────────────────
        nb_corpus   = len(doc_ids_corpus)
        nb_cites    = len(doc_ids_cites)
        taux        = round(nb_cites / nb_corpus * 100, 1) if nb_corpus > 0 else 0

        return {
            "taux_couverture_corpus": taux,
            "nb_articles_corpus":    nb_corpus,
            "nb_articles_cites":     nb_cites,
            "nb_articles_non_cites": len(non_cites),
            "articles_non_cites":    non_cites,
            "citations_fantomes":    fantomes,
            "nb_citations_fantomes": len(fantomes),
            "articles_surexploites": surexploites,
            "incoherences_metadata": incoherences,
            "nb_refs_bibliographie": len(citations_bibliographie),
            "verdict_bibliographie": (
                "coherente" if len(fantomes) == 0 and len(incoherences) == 0
                else "problemes_detectes"
            )
        }


