#  4. VÉRIFICATEUR LLM (validation croisée sémantique)
# ═════════════════════════════════════════════════════════════════════════════

class VerificateurLLM:
    """
    Pour les claims marqués "incertains" par le RAG,
    demande au LLM de vérifier si le chunk source confirme réellement le claim.

    Évite les faux positifs : un chunk peut être proche sémantiquement
    sans confirmer le claim spécifique.
    """

    def __init__(self):
        self.client = Groq(api_key=os.getenv("GROQ_API_KEY"))
        self.model  = "llama-3.3-70b-versatile"

    def verifier_claim_vs_source(self, claim: str,
                                  extrait_source: str,
                                  titre_source: str) -> dict:
        """
        Demande au LLM : "Ce passage source confirme-t-il ce claim ?"
        Retourne : verdict + justification + confiance.
        """
        prompt = f"""Tu es un expert en vérification de citations scientifiques.

CLAIM À VÉRIFIER :
"{claim}"

SOURCE POTENTIELLE (extrait de l'article "{titre_source}") :
"{extrait_source}"

TÂCHE :
Détermine si la source confirme, contredit, ou est non pertinente pour le claim.

Raisonne en 2 étapes :
1. Le claim fait-il une affirmation précise ? Laquelle ?
2. La source contient-elle une information qui confirme ou infirme cette affirmation ?

Réponds UNIQUEMENT avec un JSON valide :

{{
  "raisonnement": "ton analyse étape par étape...",
  "verdict": "confirme | contredit | non_pertinent | partiellement",
  "confiance": 0.9,
  "explication": "En une phrase : pourquoi ce verdict ?"
}}"""

        try:
            response = self.client.chat.completions.create(
                model=self.model,
                messages=[{"role": "user", "content": prompt}],
                temperature=0.1,
                max_tokens=400
            )
            raw   = response.choices[0].message.content.strip()
            match = re.search(r'\{.*\}', raw, re.DOTALL)
            if match:
                return json.loads(match.group(0))
        except Exception as e:
            print(f"  ⚠  LLM vérification échouée : {e}")

        return {
            "verdict":     "non_verifie",
            "confiance":   0.0,
            "explication": "Vérification LLM échouée.",
            "raisonnement":""
        }

    def detecter_hallucination_llm(self, claim: str,
                                    corpus_resume: str) -> dict:
        """
        Pour les claims sans source RAG, demande au LLM si
        l'affirmation est plausible ou inventée.
        """
        prompt = f"""Tu es un expert en détection d'hallucinations dans les revues de littérature.

CLAIM SANS SOURCE IDENTIFIÉE :
"{claim}"

RÉSUMÉ DU CORPUS DISPONIBLE :
{corpus_resume[:1500]}

TÂCHE :
Ce claim est-il :
1. Plausible et probable dans ce domaine (pourrait exister dans le corpus)
2. Générique et acceptable sans citation spécifique
3. Factuel précis nécessitant une source (chiffre, date, résultat)
4. Potentiellement halluciné (affirmation précise sans source trouvable)

Réponds UNIQUEMENT avec un JSON valide :

{{
  "categorie":        "plausible | generique | necessite_source | hallucination",
  "necessite_citation": true,
  "risque_hallucination": "faible | moyen | eleve",
  "explication":      "En 1-2 phrases : pourquoi ce verdict."
}}"""

        try:
            response = self.client.chat.completions.create(
                model=self.model,
                messages=[{"role": "user", "content": prompt}],
                temperature=0.1,
                max_tokens=300
            )
            raw   = response.choices[0].message.content.strip()
            match = re.search(r'\{.*\}', raw, re.DOTALL)
            if match:
                return json.loads(match.group(0))
        except Exception as e:
            print(f"  ⚠  LLM hallucination check échoué : {e}")

        return {
            "categorie":            "non_verifie",
            "necessite_citation":   True,
            "risque_hallucination": "moyen",
            "explication":          "Vérification LLM échouée."
        }


